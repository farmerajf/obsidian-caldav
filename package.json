{
  "name": "obsidian-ical",
  "version": "0.1.0",
  "description": "Two-way CalDAV sync between Obsidian frontmatter dates and Apple Calendar.",
  "type": "module",
  "private": true,
  "bin": {
    "obsidian-ical": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.3",
    "fast-xml-parser": "^4.5.1",
    "fastify": "^5.2.1",
    "gray-matter": "^4.0.3",
    "ical.js": "^2.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
